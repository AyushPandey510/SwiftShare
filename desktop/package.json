{
  "name": "swiftshare-desktop",
  "version": "1.0.0",
  "description": "SwiftShare Desktop - Offline File Sharing Application",
  "main": "public/electron.js",
  "homepage": "./",
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.0.1",
    "wait-on": "^7.0.1",
    "cross-env": "^7.0.3",
    "axios": "^1.6.0",
    "socket.io-client": "^4.7.2",
    "react-router-dom": "^6.14.1",
    "react-dropzone": "^14.2.3",
    "react-qr-code": "^2.0.12",
    "html5-qrcode": "^2.3.8",
    "react-icons": "^4.10.1",
    "framer-motion": "^10.15.1",
    "tailwindcss": "^3.3.2",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "@headlessui/react": "^1.7.15",
    "@heroicons/react": "^2.0.18",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "zustand": "^4.4.1",
    "ws": "^8.14.2",
    "file-saver": "^2.0.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "wait-on tcp:3000 && cross-env BROWSER=none electron .",
    "electron-dev": "concurrently -k \"cross-env BROWSER=none npm start\" \"npm:electron\"",
    "electron-pack": "npm run build && electron-builder -c.extraMetadata.main=build/electron.js",
    "preelectron-pack": "npm run build",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.swiftshare.desktop",
    "productName": "SwiftShare",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/uuid": "^9.0.2",
    "@types/file-saver": "^2.0.7"
  }
} 